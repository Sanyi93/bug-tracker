pipeline {
    agent any

    stages {
        stage('Unit Tests - Backend') { //adding an agent/docker container with go installed in order to be able to run via jenkins
            agent {
                docker{
                    image 'snakee/golang-junit:1.21'
                    reuseNode true
                }
            }
            steps {
                dir('bugtracker-backend'){
                    sh 'go test -v ./...'
                }

            }
        }
    }
}